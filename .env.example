# ============================================
# ConvertAI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ConvertAI
NODE_ENV=development

# ----- Database (PostgreSQL) -----
DATABASE_URL="postgresql://postgres:password@localhost:5432/convertai?schema=public"

# ----- Auth (NextAuth) -----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-this

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----- Groq AI (for OCR text enhancement, document analysis) -----
GROQ_API_KEY=your_groq_api_key_here
# Get from: https://console.groq.com/keys
# Models available: llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768

# ----- AWS S3 (File Storage) -----
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=convertai-files

# ----- Alternatively: Cloudinary -----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----- Redis (Queue & Cache) -----
REDIS_URL=redis://localhost:6379

# ----- Stripe (Payments) -----
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Price IDs
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx

# ----- Razorpay (Payments - India) -----
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id

# ----- Email (SMTP) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@convertai.com

# ----- Google Vision API (Optional OCR) -----
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# ----- Azure OCR (Optional) -----
AZURE_COMPUTER_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_COMPUTER_VISION_KEY=your-azure-key

# ----- File Limits -----
MAX_FILE_SIZE_FREE=10485760
# 10MB = 10 * 1024 * 1024
MAX_FILE_SIZE_PRO=104857600
# 100MB
DAILY_CONVERSION_LIMIT_FREE=10

# ----- Admin -----
ADMIN_EMAIL=admin@convertai.com
ADMIN_PASSWORD=change-this-admin-password

# ----- Security -----
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
ENCRYPTION_KEY=your-32-char-encryption-key-here
